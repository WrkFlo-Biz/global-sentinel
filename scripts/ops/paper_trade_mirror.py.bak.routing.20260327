# ============ QUANTUM FEED SIGNAL LOADING ============

QUANTUM_FEED = REPO_ROOT / "data" / "quantum_feed"


def load_orb_signals():
    """Load ORB (Opening Range Breakout) signals from quantum feed."""
    try:
        path = QUANTUM_FEED / "orb_signals.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        summary = data.get("multi_tf_summary", {})
        signals = {}
        for sym, info in summary.items():
            direction = info.get("direction", "NEUTRAL")
            alignment = info.get("alignment", 0)
            if direction != "NEUTRAL" and alignment >= 2:
                signals[sym] = {
                    "source": "orb",
                    "direction": "long" if direction == "BULLISH" else "short",
                    "strength": alignment / 4.0,
                    "timeframes": {k: v for k, v in info.items() if k not in ("alignment", "direction")}
                }
        for sig in data.get("actionable", []):
            sym = sig.get("symbol", "")
            if sym:
                signals[sym] = {
                    "source": "orb_breakout",
                    "direction": sig.get("direction", "long").lower(),
                    "strength": 0.8,
                    "entry": sig.get("entry"),
                    "target": sig.get("target"),
                    "stop": sig.get("stop"),
                }
        return signals
    except Exception as e:
        log(f"[SIGNALS] ORB load error: {e}")
        return {}


def load_ict_smc_signals():
    """Load ICT/Smart Money Concept signals from quantum feed."""
    try:
        path = QUANTUM_FEED / "ict_smc_signals.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        signals = {}
        for sig in data.get("smart_money_signals", []):
            sym = sig.get("symbol", "")
            if sym and sig.get("confluence_score", 0) >= 4:
                signals[sym] = {
                    "source": "ict_smc",
                    "direction": sig.get("direction", "long"),
                    "strength": sig.get("confluence_score", 0) / sig.get("max_score", 9),
                    "confidence": sig.get("confidence", 0),
                    "entry": sig.get("entry"),
                    "stop": sig.get("stop"),
                    "target": sig.get("target"),
                    "zone": sig.get("zone"),
                    "components": sig.get("components", {}),
                }
        return signals
    except Exception as e:
        log(f"[SIGNALS] ICT/SMC load error: {e}")
        return {}


def load_ensemble_signals():
    """Load multi-agent ensemble consensus signals from quantum feed."""
    try:
        path = QUANTUM_FEED / "ensemble_signals.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        signals = {}
        for sig in data.get("signals", []):
            sym = sig.get("symbol", "")
            ensemble_val = sig.get("ensemble_signal", 0)
            if sym and abs(ensemble_val) >= 0.05:
                signals[sym] = {
                    "source": "ensemble",
                    "direction": sig.get("direction", "long"),
                    "strength": abs(ensemble_val),
                    "confidence": sig.get("confidence", 0),
                    "agent_signals": sig.get("agent_signals", {}),
                }
        return signals
    except Exception as e:
        log(f"[SIGNALS] Ensemble load error: {e}")
        return {}


def load_kelly_sizing():
    """Load Kelly Criterion position sizing recommendations."""
    try:
        path = QUANTUM_FEED / "kelly_sizing.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        return {
            "equity": data.get("equity", 100000),
            "strategies": data.get("strategies", {}),
        }
    except Exception as e:
        log(f"[SIGNALS] Kelly sizing load error: {e}")
        return {}


def load_overnight_gap_signals():
    """Load overnight gap analysis signals."""
    try:
        path = QUANTUM_FEED / "overnight_gap_signals.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        signals = {}
        for sig in data.get("signals", data.get("gaps", [])):
            sym = sig.get("symbol", "")
            if sym:
                gap_pct = sig.get("gap_pct", sig.get("gap_percent", 0))
                signals[sym] = {
                    "source": "overnight_gap",
                    "direction": "long" if gap_pct > 0 else "short",
                    "strength": min(abs(gap_pct) / 3.0, 1.0),
                    "gap_pct": gap_pct,
                    "gap_type": sig.get("gap_type", "unknown"),
                }
        return signals
    except Exception as e:
        log(f"[SIGNALS] Overnight gap load error: {e}")
        return {}


def load_scalping_signals():
    """Load scalping engine signals from quantum feed."""
    try:
        path = QUANTUM_FEED / "scalping_signals.json"
        if not path.exists():
            return {}
        data = json.loads(path.read_text())
        signals = {}
        for sig in data.get("signals", []):
            sym = sig.get("symbol", "")
            if sym and sig.get("confidence", 0) >= 0.5:
                signals[sym] = {
                    "source": "scalping",
                    "direction": sig.get("direction", "long"),
                    "strength": sig.get("confidence", 0.5),
                    "entry": sig.get("entry"),
                    "stop": sig.get("stop"),
                    "target": sig.get("target"),
                    "risk_reward": sig.get("risk_reward", 0),
                    "type": sig.get("type", "unknown"),
                }
        return signals
    except Exception as e:
        log(f"[SIGNALS] Scalping load error: {e}")
        return {}


def aggregate_signals(symbol):
    """Aggregate all signal sources for a symbol. Returns dict with consensus info."""
    orb = load_orb_signals()
    ict = load_ict_smc_signals()
    ensemble = load_ensemble_signals()
    gap = load_overnight_gap_signals()
    scalp = load_scalping_signals()

    sources = {}
    if symbol in orb:
        sources["orb"] = orb[symbol]
    if symbol in ict:
        sources["ict_smc"] = ict[symbol]
    if symbol in ensemble:
        sources["ensemble"] = ensemble[symbol]
    if symbol in gap:
        sources["overnight_gap"] = gap[symbol]
    if symbol in scalp:
        sources["scalping"] = scalp[symbol]

    if not sources:
        return {"symbol": symbol, "agreeing_sources": 0, "direction": None, "sources": {}}

    # Count direction agreement
    directions = {}
    for name, sig in sources.items():
        d = sig.get("direction", "").lower()
        if d in ("long", "bullish"):
            d = "long"
        elif d in ("short", "bearish"):
            d = "short"
        else:
            continue
        directions[d] = directions.get(d, 0) + 1

    if not directions:
        return {"symbol": symbol, "agreeing_sources": 0, "direction": None, "sources": sources}

    best_dir = max(directions, key=directions.get)
    agreeing = directions[best_dir]

    # Average strength from agreeing sources
    strengths = []
    for name, sig in sources.items():
        d = sig.get("direction", "").lower()
        if d in ("long", "bullish"):
            d = "long"
        elif d in ("short", "bearish"):
            d = "short"
        if d == best_dir:
            strengths.append(sig.get("strength", 0.5))

    avg_strength = sum(strengths) / len(strengths) if strengths else 0

    return {
        "symbol": symbol,
        "agreeing_sources": agreeing,
        "total_sources": len(sources),
        "direction": best_dir,
        "avg_strength": avg_strength,
        "sources": sources,
    }


def get_kelly_position_size(equity, strategy_name="day_trade_momentum"):
    """Get Kelly-recommended position size for a strategy."""
    kelly = load_kelly_sizing()
    if not kelly:
        return equity * 0.01
    strats = kelly.get("strategies", {})
    strat = strats.get(strategy_name, {})
    qk = strat.get("quarter_kelly", 0)
    position_pct = strat.get("position_pct", 0.01)
    use_pct = max(qk, position_pct)
    use_pct = min(use_pct, 0.12)  # cap at 12%
    dollar_size = kelly.get("equity", equity) * use_pct
    return max(dollar_size, 1000.0)


