def get_session_multiplier():
    try:
        import sys; sys.path.insert(0, "/opt/global-sentinel")
        from src.research.session_intelligence import get_current_session, STRATEGIES
        session = get_current_session()
        strat = STRATEGIES.get(session, {})
        return strat.get("size_multiplier", 0.5), strat.get("entry_quality", 0.3), session
    except:
        return 0.5, 0.3, "unknown"

def log(msg):
    ts = datetime.datetime.now(datetime.timezone.utc).isoformat()
    print(f"[{ts}] {msg}", flush=True)

def now_et():
    from datetime import timezone, timedelta
    utc = datetime.datetime.now(timezone.utc)
    et = utc - timedelta(hours=4)  # EDT approximation
    return et

def alpaca_request(base, key, secret, method, path, data=None):
    # Drawdown circuit breaker gate — block new orders when tripped
    if _DRAWDOWN_BREAKER and method == "POST" and "/v2/orders" in path:
        if not _gate_order("paper"):
            log("Circuit breaker active -- halting new trades")
            return None

    if _SMART_ROUTER and method == "POST" and "/v2/orders" in path and data:
        try:
            result = _route_alpaca_order(base, key, secret, method, path, data)
            if result is not None:
                log(f"[SMART-ROUTER] Order routed: {data.get('symbol', '?')} {data.get('side', '?')} via router")
                return result
            else:
                log(f"[SMART-ROUTER] Router returned None, falling back to direct Alpaca")
        except Exception as e:
            log(f"[SMART-ROUTER] Error, falling back to direct: {e}")

    url = f"{base}{path}"
    body = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=body, method=method)
    req.add_header("APCA-API-KEY-ID", key)
    req.add_header("APCA-API-SECRET-KEY", secret)
    if body:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = e.read().decode() if e.fp else str(e)
        log(f"API error {e.code}: {err[:200]}")
        return None
    except Exception as e:
        log(f"Request error: {e}")
        return None

def data_request(path):
    """Use live account for market data."""
    url = f"https://data.alpaca.markets{path}"
    req = urllib.request.Request(url)
    req.add_header("APCA-API-KEY-ID", LIVE_KEY)
    req.add_header("APCA-API-SECRET-KEY", LIVE_SECRET)
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except Exception as e:
        log(f"Data error: {e}")
        return None

def send_telegram(msg):
    if not TG_TOKEN or not TG_CHAT:
        return
    try:
        payload = json.dumps({
            "chat_id": TG_CHAT, "text": msg, "parse_mode": "HTML",
            "message_thread_id": int(TG_THREAD), "disable_notification": True
        }).encode()
        req = urllib.request.Request(
            f"https://api.telegram.org/bot{TG_TOKEN}/sendMessage",
            data=payload, headers={"Content-Type": "application/json"})
        urllib.request.urlopen(req, timeout=10)
    except Exception as e:
        log(f"Telegram error: {e}")

def get_previous_closes():
    """Get previous day's close for all scan tickers."""
    syms = ",".join(SCAN_TICKERS)
    data = data_request(f"/v2/stocks/bars?symbols={syms}&timeframe=1Day&limit=1&sort=desc")
    closes = {}
    if data and "bars" in data:
        for sym, bars in data["bars"].items():
            if bars:
                closes[sym] = bars[0]["c"]
    return closes

def get_current_quotes():
    """Get latest quotes for all scan tickers."""
    syms = ",".join(SCAN_TICKERS)
    data = data_request(f"/v2/stocks/quotes/latest?symbols={syms}")
    quotes = {}
    if data and "quotes" in data:
        for sym, q in data["quotes"].items():
            quotes[sym] = (q["bp"] + q["ap"]) / 2
    return quotes

def find_top_movers(closes, quotes, n=3):
    """Find top n movers using price change + quantum/ensemble signals."""
    movers = []
    ensemble = {}
    try:
        import json as _json
        epath = REPO_ROOT / "data/quantum_feed/ensemble_signals.json"
        if epath.exists():
            edata = _json.loads(epath.read_text())
            for s in edata.get("signals", []):
                ensemble[s["symbol"]] = s.get("ensemble_signal", 0)
    except:
        pass

    alpha = {}
    try:
        apath = REPO_ROOT / "data/quantum_feed/qlib_alpha_scores.json"
        if apath.exists():
            adata = _json.loads(apath.read_text())
            for s in adata.get("scores", []):
                alpha[s["symbol"]] = s.get("alpha_score", 0)
    except:
        pass

    for sym in SCAN_TICKERS:
        if sym in closes and sym in quotes:
            pct = (quotes[sym] - closes[sym]) / closes[sym] * 100
            boost = ensemble.get(sym, 0) * 50 + alpha.get(sym, 0) * 100
            combined = abs(pct) + abs(boost)
            movers.append((combined, pct + boost, sym, quotes[sym]))
    movers.sort(reverse=True)
    return movers[:n]

def find_option(symbol, price, direction, expiry_date):
    """Find ATM option using Alpaca options chain API."""
    contract_type = "call" if direction > 0 else "put"
    try:
        exp = expiry_date.strftime("%Y-%m-%d")
        strike_min = round(price - 2)
        strike_max = round(price + 2)
        url = f"https://data.alpaca.markets/v1beta1/options/snapshots/{symbol}?feed=indicative&type={contract_type}&strike_price_gte={strike_min}&strike_price_lte={strike_max}&expiration_date={exp}&limit=5"
        req = urllib.request.Request(url)
        req.add_header("APCA-API-KEY-ID", LIVE_KEY)
        req.add_header("APCA-API-SECRET-KEY", LIVE_SECRET)
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read())
        snapshots = data.get("snapshots", {})
        best = None
        best_spread = 999
        for opt_sym, snap in snapshots.items():
            q = snap.get("latestQuote", {})
            bid = q.get("bp", 0)
            ask = q.get("ap", 0)
            if bid > 0 and ask > 0 and ask < 3.0:
                spread = (ask - bid) / ((ask + bid) / 2)
                if spread < best_spread:
                    best_spread = spread
                    best = {"symbol": opt_sym, "bid": bid, "ask": ask, "type": contract_type}
        return best
    except Exception as e:
        log(f"Option chain error for {symbol}: {e}")
        return None

    # Fallback: try weekly expiry if 0DTE not available
    if best is None:
        try:
            from datetime import timedelta
            next_friday = expiry_date
            while next_friday.weekday() != 4:
                next_friday += timedelta(days=1)
            if next_friday != expiry_date:
                exp2 = next_friday.strftime("%Y-%m-%d")
                url2 = f"https://data.alpaca.markets/v1beta1/options/snapshots/{symbol}?feed=indicative&type={contract_type}&strike_price_gte={strike_min}&strike_price_lte={strike_max}&expiration_date={exp2}&limit=5"
                req2 = urllib.request.Request(url2)
                req2.add_header("APCA-API-KEY-ID", LIVE_KEY)
                req2.add_header("APCA-API-SECRET-KEY", LIVE_SECRET)
                with urllib.request.urlopen(req2, timeout=15) as resp2:
                    data2 = json.loads(resp2.read())
                for opt_sym, snap in data2.get("snapshots", {}).items():
                    q = snap.get("latestQuote", {})
                    bid = q.get("bp", 0)
                    ask = q.get("ap", 0)
                    if bid > 0 and ask > 0 and ask < 3.0:
                        return {"symbol": opt_sym, "bid": bid, "ask": ask, "type": contract_type}
        except:
            pass
    return best

# ============ DAY TRADE LOGIC ============

def day_trade_scan_and_enter():
    """Scan for momentum + multi-signal consensus and enter day trade positions."""
    log("DAY TRADE: Scanning with multi-signal consensus...")
    closes = get_previous_closes()
    quotes = get_current_quotes()
    if not closes or not quotes:
        log("DAY TRADE: No data available")
        return []

    movers = find_top_movers(closes, quotes, n=10)  # Scan more candidates
    log(f"DAY TRADE: Top movers: {[(m[2], f'{m[1]:+.2f}%') for m in movers]}")

    # Aggregate signals for all movers
    signal_candidates = []
    for _, pct, sym, price in movers:
        agg = aggregate_signals(sym)
        src_names = list(agg["sources"].keys())
        log(f"DAY TRADE: {sym} signals: {agg['agreeing_sources']} sources agree "
            f"on {agg['direction']}, strength={agg.get('avg_strength', 0):.2f}, "
            f"sources={src_names}")
        signal_candidates.append((agg, pct, sym, price))

    # Filter: prefer 3+ agreeing sources, fallback to 2+
    strong = [c for c in signal_candidates if c[0]["agreeing_sources"] >= 3]
    moderate = [c for c in signal_candidates if c[0]["agreeing_sources"] >= 2]

    if strong:
        candidates = strong
        log(f"DAY TRADE: {len(strong)} candidates with 3+ signal consensus")
    elif moderate:
        candidates = moderate
        log(f"DAY TRADE: {len(moderate)} candidates with 2+ signal consensus (no 3+ found)")
    else:
        log("DAY TRADE: No multi-signal consensus found, using top 3 movers (momentum only)")
        candidates = signal_candidates[:3]

    # Sort by agreement count, then strength
    candidates.sort(
        key=lambda x: (x[0]["agreeing_sources"], x[0].get("avg_strength", 0)),
        reverse=True
    )

    # Get Kelly position sizing
    acct_check = alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "GET", "/v2/account")
    dt_equity = float(acct_check.get("equity", 100000)) if acct_check else 100000
    kelly_size = get_kelly_position_size(dt_equity, "day_trade_momentum")
    log(f"DAY TRADE: Kelly recommended size: ${kelly_size:.0f} (equity: ${dt_equity:.0f})")

    today = now_et().date()
    positions = []
    for agg, pct, sym, price in candidates[:3]:
        # Use signal direction if available, else price momentum
        if agg["direction"]:
            direction = 1 if agg["direction"] == "long" else -1
        else:
            direction = 1 if pct > 0 else -1

        option = find_option(sym, price, direction, today)
        if not option:
            log(f"DAY TRADE: No option found for {sym}")
            continue

        cost = option["ask"] * 100
        acct = alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "GET", "/v2/account")
        if not acct:
            continue
        bp = float(acct.get("options_buying_power", 0))
        if cost > bp:
            log(f"DAY TRADE: {option['symbol']} costs ${cost:.0f}, only ${bp:.0f} BP")
            continue

        # Determine quantity using Kelly sizing
        max_contracts = max(1, int(kelly_size / cost))
        qty = min(max_contracts, 3)  # Cap at 3 contracts per trade

        # Correlation guard check
        if _CORR_GUARD:
            try:
                guard_result = _check_position_guard(sym, account="day_trade")
                if not guard_result.get("allowed", True):
                    log(f"DAY TRADE: BLOCKED by correlation guard: {guard_result.get('reason', '?')}")
                    continue
                for w in guard_result.get("warnings", []):
                    log(f"DAY TRADE: Guard warning: {w}")
            except Exception as e:
                log(f"DAY TRADE: Correlation guard error (proceeding): {e}")

        order = alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "POST", "/v2/orders", {
            "symbol": option["symbol"],
            "qty": str(qty),
            "side": "buy",
            "type": "limit",
            "time_in_force": "day",
            "limit_price": str(option["ask"]),
            "position_intent": "buy_to_open"
        })
        if order and order.get("status") in ("pending_new", "accepted", "new", "filled"):
            # Build signal trigger log
            triggered_signals = {}
            for src_name, src_data in agg.get("sources", {}).items():
                triggered_signals[src_name] = {
                    "direction": src_data.get("direction"),
                    "strength": src_data.get("strength"),
                    "confidence": src_data.get("confidence"),
                }

            entry = {
                "symbol": option["symbol"],
                "underlying": sym,
                "direction": "call" if direction > 0 else "put",
                "entry_price": option["ask"],
                "entry_time": datetime.datetime.now(datetime.timezone.utc).isoformat(),
                "underlying_price": price,
                "pct_move": pct,
                "high_water_mark": option["ask"],
                "breakeven_stop_active": False,
                "order_id": order.get("id", ""),
                "status": "open",
                "qty": qty,
                "signal_consensus": {
                    "agreeing_sources": agg["agreeing_sources"],
                    "total_sources": agg.get("total_sources", 0),
                    "consensus_direction": agg["direction"],
                    "avg_strength": agg.get("avg_strength", 0),
                    "triggered_signals": triggered_signals,
                },
                "kelly_size_used": kelly_size,
            }
            positions.append(entry)
            signal_list = list(triggered_signals.keys())
            log(f"DAY TRADE: Entered {qty}x {option['symbol']} @ ${option['ask']:.2f} "
                f"({sym} {pct:+.2f}%) [signals: {signal_list}, "
                f"consensus: {agg['agreeing_sources']}/{agg.get('total_sources', 0)}]")
        time.sleep(1)

    return positions

def day_trade_monitor(positions):
    """Monitor day trade positions, manage stops."""
    for pos in positions:
        if pos["status"] != "open":
            continue
        resp = alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "GET", f"/v2/positions/{pos['symbol']}")
        if not resp:
            pos["status"] = "closed_unknown"
            continue

        current = float(resp.get("current_price", 0))
        entry = pos["entry_price"]
        pnl_pct = (current - entry) / entry * 100 if entry > 0 else 0

        if current > pos["high_water_mark"]:
            pos["high_water_mark"] = current

        if pnl_pct >= 50 and not pos["breakeven_stop_active"]:
            pos["breakeven_stop_active"] = True
            log(f"DAY TRADE: {pos['symbol']} breakeven stop activated at +{pnl_pct:.1f}%")

        if pos["breakeven_stop_active"]:
            drop_from_high = (pos["high_water_mark"] - current) / pos["high_water_mark"] * 100
            if drop_from_high >= 15:
                qty = pos.get("qty", 1)
                sell_order = alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "POST", "/v2/orders", {
                    "symbol": pos["symbol"], "qty": str(qty), "side": "sell",
                    "type": "limit", "time_in_force": "day",
                    "limit_price": str(round(current * 0.97, 2)),
                    "position_intent": "sell_to_close"
                })
                pos["status"] = "sold_reversal"
                pos["exit_price"] = current
                pos["exit_time"] = datetime.datetime.now(datetime.timezone.utc).isoformat()
                log(f"DAY TRADE: Sold {pos['symbol']} @ ${current:.2f} (reversal from HWM ${pos['high_water_mark']:.2f})")

        pos["current_price"] = current
        pos["pnl_pct"] = pnl_pct
        time.sleep(0.5)

def day_trade_close_all(positions):
    """Close all remaining day trade positions."""
    log("DAY TRADE: Closing all remaining positions...")
    alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "DELETE", "/v2/orders")
    time.sleep(2)
    alpaca_request(DT_BASE, DT_KEY, DT_SECRET, "DELETE", "/v2/positions")
    for pos in positions:
        if pos["status"] == "open":
            pos["status"] = "closed_eod"
            pos["exit_price"] = pos.get("current_price", pos["entry_price"])
            pos["exit_time"] = datetime.datetime.now(datetime.timezone.utc).isoformat()

def day_trade_report(positions, date_str):
    """Generate daily report with signal attribution."""
    total_pnl = 0
    for pos in positions:
        entry = pos.get("entry_price", 0)
        exit_p = pos.get("exit_price", pos.get("current_price", entry))
        qty = pos.get("qty", 1)
        pnl = (exit_p - entry) * 100 * qty
        pos["realized_pnl"] = pnl
        total_pnl += pnl

    # Signal attribution
    signal_attribution = {}
    for pos in positions:
        sc = pos.get("signal_consensus", {})
        for sig_name in sc.get("triggered_signals", {}):
            if sig_name not in signal_attribution:
                signal_attribution[sig_name] = {"trades": 0, "pnl": 0, "wins": 0}
            signal_attribution[sig_name]["trades"] += 1
            signal_attribution[sig_name]["pnl"] += pos.get("realized_pnl", 0)
            if pos.get("realized_pnl", 0) > 0:
                signal_attribution[sig_name]["wins"] += 1

    report = {
        "date": date_str,
        "strategy": "day_trade_momentum",
        "positions": positions,
        "total_pnl": round(total_pnl, 2),
        "num_trades": len(positions),
        "winners": sum(1 for p in positions if p.get("realized_pnl", 0) > 0),
        "losers": sum(1 for p in positions if p.get("realized_pnl", 0) <= 0),
        "signal_attribution": signal_attribution,
        "signal_consensus_stats": {
            "avg_agreeing_sources": (
                sum(p.get("signal_consensus", {}).get("agreeing_sources", 0) for p in positions) / len(positions)
                if positions else 0
            ),
            "trades_with_3plus_consensus": sum(
                1 for p in positions
                if p.get("signal_consensus", {}).get("agreeing_sources", 0) >= 3
            ),
        },
    }

    path = REPORTS_DIR / f"day_trade_{date_str}.json"
    path.write_text(json.dumps(report, indent=2))
    log(f"DAY TRADE: Report saved to {path}")

    # Append to trade feedback dataset for Kelly sizer
    feedback_path = QUANTUM_FEED / "trade_feedback_dataset.jsonl"
    try:
        with open(feedback_path, "a") as f:
            for pos in positions:
                feedback = {
                    "timestamp": pos.get("entry_time"),
                    "symbol": pos.get("underlying"),
                    "strategy": "day_trade_momentum",
                    "entry_price": pos.get("entry_price"),
                    "exit_price": pos.get("exit_price"),
                    "pnl": pos.get("realized_pnl", 0),
                    "signal_consensus": pos.get("signal_consensus", {}),
                    "kelly_size": pos.get("kelly_size_used"),
                }
                f.write(json.dumps(feedback) + "\n")
    except Exception as e:
        log(f"DAY TRADE: Feedback write error: {e}")

    return report

# ============ MEDIUM/LONG LOGIC ============

def medlong_scan_and_enter():
    """Scan for swing trade setups using multi-signal consensus."""
    log("MEDLONG: Scanning for swing trade setups with signal consensus...")
    closes = get_previous_closes()
    quotes = get_current_quotes()
    if not closes or not quotes:
        return []

    movers = find_top_movers(closes, quotes, n=10)

    acct = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/account")
    if not acct:
        return []
    equity = float(acct.get("equity", 0))

    kelly_size = get_kelly_position_size(equity, "stocks")
    log(f"MEDLONG: Kelly recommended size: ${kelly_size:.0f} (equity: ${equity:.0f})")

    existing = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/positions")
    existing_syms = {p["symbol"] for p in (existing or [])}

    positions = []
    for _, pct, sym, price in movers[:8]:
        if sym in existing_syms:
            log(f"MEDLONG: Already holding {sym}, skip")
            continue

        agg = aggregate_signals(sym)
        src_names = list(agg["sources"].keys())
        log(f"MEDLONG: {sym} signals: {agg['agreeing_sources']} sources, "
            f"dir={agg['direction']}, strength={agg.get('avg_strength', 0):.2f}, "
            f"sources={src_names}")

        if agg["agreeing_sources"] < 2:
            log(f"MEDLONG: {sym} insufficient signal consensus ({agg['agreeing_sources']}), skip")
            continue

        if agg["direction"] == "short":
            continue
        if pct < 0 and not agg["direction"]:
            continue

        position_size = kelly_size * (1 + agg.get("avg_strength", 0))
        position_size = min(position_size, equity * 0.10)
        qty = max(1, int(position_size / price))

        # Correlation guard check
        if _CORR_GUARD:
            try:
                guard_result = _check_position_guard(sym, account="medlong")
                if not guard_result.get("allowed", True):
                    log(f"MEDLONG: BLOCKED by correlation guard: {guard_result.get('reason', '?')}")
                    continue
                for w in guard_result.get("warnings", []):
                    log(f"MEDLONG: Guard warning: {w}")
            except Exception as e:
                log(f"MEDLONG: Correlation guard error (proceeding): {e}")

        order = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "POST", "/v2/orders", {
            "symbol": sym, "qty": str(qty), "side": "buy",
            "type": "market", "time_in_force": "day"
        })
        if order and order.get("status") in ("pending_new", "accepted", "new", "filled"):
            triggered_signals = {}
            for src_name, src_data in agg.get("sources", {}).items():
                triggered_signals[src_name] = {
                    "direction": src_data.get("direction"),
                    "strength": src_data.get("strength"),
                }

            entry = {
                "symbol": sym, "qty": qty, "entry_price": price,
                "entry_time": datetime.datetime.now(datetime.timezone.utc).isoformat(),
                "pct_move_at_entry": pct,
                "stop_loss": round(price * 0.95, 2),
                "take_profit": round(price * 1.10, 2),
                "status": "open",
                "signal_consensus": {
                    "agreeing_sources": agg["agreeing_sources"],
                    "total_sources": agg.get("total_sources", 0),
                    "consensus_direction": agg["direction"],
                    "avg_strength": agg.get("avg_strength", 0),
                    "triggered_signals": triggered_signals,
                },
                "kelly_size_used": position_size,
            }
            positions.append(entry)
            log(f"MEDLONG: Bought {qty} {sym} @ ~${price:.2f} ({pct:+.2f}%) "
                f"[signals: {list(triggered_signals.keys())}, "
                f"consensus: {agg['agreeing_sources']}/{agg.get('total_sources', 0)}]")
        time.sleep(1)

    return positions

def medlong_check_positions():
    """Check medium/long positions for stop loss / take profit."""
    positions = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/positions")
    if not positions:
        return

    for pos in positions:
        sym = pos["symbol"]
        current = float(pos["current_price"])
        entry = float(pos["avg_entry_price"])
        pnl_pct = (current - entry) / entry * 100

        if pnl_pct <= -5:
            alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "DELETE", f"/v2/positions/{sym}")
            log(f"MEDLONG: Stop loss hit on {sym} ({pnl_pct:+.2f}%)")
        elif pnl_pct >= 10:
            alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "DELETE", f"/v2/positions/{sym}")
            log(f"MEDLONG: Take profit hit on {sym} ({pnl_pct:+.2f}%)")

def medlong_weekly_report():
    """Generate weekly report."""
    positions = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/positions")
    acct = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/account")
    history = alpaca_request(ML_BASE, ML_KEY, ML_SECRET, "GET", "/v2/account/portfolio/history?period=1W&timeframe=1D")

    week = now_et().strftime("%Y-W%W")
    report = {
        "week": week,
        "equity": float(acct["equity"]) if acct else 0,
        "positions": len(positions) if positions else 0,
        "portfolio_history": history,
    }

    path = REPORTS_DIR / f"medlong_week_{week}.json"
    path.write_text(json.dumps(report, indent=2, default=str))
    log(f"MEDLONG: Weekly report saved to {path}")
    return report

# ============ MAIN LOOP ============

def run():
    log("Paper Trade Mirror starting (multi-signal consensus mode)...")
    dt_positions = []
    dt_entered = False
    ml_entered_today = False
    last_ml_check = 0

    while True:
        try:
            et = now_et()
            hour, minute = et.hour, et.minute
            market_minutes = hour * 60 + minute
            weekday = et.weekday()

            if weekday >= 5:
                log("Weekend - sleeping 1 hour")
                time.sleep(3600)
                continue

            market_open = 9 * 60 + 30
            market_close = 16 * 60

            if market_minutes < market_open - 5 or market_minutes > market_close + 10:
                if market_minutes > market_close + 10:
                    dt_entered = False
                    ml_entered_today = False
                time.sleep(60)
                continue

            # Check drawdown circuit breaker P&L thresholds
            if _DRAWDOWN_BREAKER and market_minutes >= (9 * 60 + 30):
                try:
                    _check_daily_pnl(DT_BASE, DT_KEY, DT_SECRET, "day_trade")
                except Exception as _cb_e:
                    log(f"Circuit breaker check error: {_cb_e}")

            if market_minutes >= (9 * 60 + 35) and not dt_entered:
                dt_positions = day_trade_scan_and_enter()
                dt_entered = True

                if not ml_entered_today:
                    medlong_scan_and_enter()
                    ml_entered_today = True

            if dt_positions and market_minutes < (15 * 60 + 50):
                day_trade_monitor(dt_positions)

            if time.time() - last_ml_check > 1800:
                medlong_check_positions()
                last_ml_check = time.time()

            if market_minutes >= (15 * 60 + 50):
                day_trade_close_all(dt_positions)
                date_str = et.strftime("%Y-%m-%d")
                report = day_trade_report(dt_positions, date_str)

                msg = f"<b>Paper Day Trade Report - {date_str}</b>\n"
                msg += f"Trades: {report['num_trades']} | W: {report['winners']} L: {report['losers']}\n"
                msg += f"Total P&L: ${report['total_pnl']:.2f}\n"
                for p in dt_positions:
                    sc = p.get("signal_consensus", {})
                    sigs = list(sc.get("triggered_signals", {}).keys())
                    msg += f"  {p['underlying']} {p['direction']}: ${p.get('realized_pnl',0):.2f}"
                    if sigs:
                        msg += f" [{','.join(sigs)}]"
                    msg += "\n"
                sa = report.get("signal_attribution", {})
                if sa:
                    msg += "\n<b>Signal Attribution:</b>\n"
                    for sig_name, stats in sa.items():
                        wr = (stats['wins'] / stats['trades'] * 100) if stats['trades'] > 0 else 0
                        msg += f"  {sig_name}: {stats['trades']} trades, ${stats['pnl']:.2f} P&L, {wr:.0f}% WR\n"
                send_telegram(msg)

                dt_positions = []

            if weekday == 4 and market_minutes >= (15 * 60 + 55):
                medlong_weekly_report()

            time.sleep(300)

        except KeyboardInterrupt:
            log("Shutting down...")
            if dt_positions:
                day_trade_close_all(dt_positions)
            break
        except Exception as e:
            log(f"Error: {e}\n{traceback.format_exc()}")
            time.sleep(60)

if __name__ == "__main__":
    run()
