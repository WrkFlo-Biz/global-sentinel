            {"symbol": "ZS", "action": "buy", "notional_pct": 5.0, "account": "daytrade", "reason": "cyber_attack"},
        ],
    },
}

# Trigger thresholds
PEACE_PROB_THRESHOLD_HIGH = 50.0   # Peace probability crossing above 50%
PEACE_PROB_THRESHOLD_LOW = 20.0    # Peace probability dropping below 20% → escalation
WAR_INTENSITY_JUMP = 2.0           # War intensity score jump >2 points in 1 hour
BREAKING_NEWS_KEYWORDS = {
    "peace": ["ceasefire", "peace deal", "peace agreement", "peace talks progress", "armistice", "truce"],
    "escalation": ["escalation", "strike", "attack", "bombing", "missile launch", "invasion",
                    "troops deployed", "war declared", "nuclear threat", "retaliation"],
    "oil_shock": ["oil supply disruption", "hormuz closed", "pipeline attack", "refinery attack",
                  "opec emergency", "oil embargo", "oil 150", "oil shock"],
    "cyber": ["cyberattack", "cyber warfare", "ransomware attack", "infrastructure hack",
              "power grid attack", "state-sponsored hack", "critical infrastructure breach"],
}

POLL_INTERVAL_SECONDS = 30
COOLDOWN_SECONDS = 3600  # 1 hour cooldown between triggering same package


class ConditionalOrderEngine:
    """Monitors signals and triggers pre-staged order packages."""

    def __init__(self):
        self.project_root = PROJECT_ROOT
        self.signal_path = self.project_root / "data" / "quantum_feed" / "latest_signal.json"
        self.polymarket_path = self.project_root / "data" / "quantum_feed" / "polymarket_geopolitical.json"
        self.log_path = self.project_root / "data" / "conditional_order_log.jsonl"
        self._last_triggers: Dict[str, float] = {}  # package_name -> last trigger timestamp
        self._last_war_intensity: Optional[float] = None
        self._last_war_intensity_time: Optional[float] = None

        # Alpaca config from environment
        self._daytrade_key = os.environ.get("ALPACA_API_KEY_DAYTRADE") or os.environ.get("ALPACA_API_KEY", "")
        self._daytrade_secret = os.environ.get("ALPACA_SECRET_KEY_DAYTRADE") or os.environ.get("ALPACA_SECRET_KEY", "")
        self._medlong_key = os.environ.get("ALPACA_API_KEY_MEDLONG", "")
        self._medlong_secret = os.environ.get("ALPACA_SECRET_KEY_MEDLONG", "")
        self._base_url = os.environ.get("ALPACA_BASE_URL", "https://paper-api.alpaca.markets")

    def _read_json(self, path: Path) -> Optional[Dict]:
        try:
            if path.exists():
                return json.loads(path.read_text(encoding="utf-8"))
        except Exception as exc:
            logger.debug("Failed to read %s: %s", path, exc)
        return None

    def _is_cooled_down(self, package_name: str) -> bool:
        last = self._last_triggers.get(package_name, 0)
        return (time.time() - last) >= COOLDOWN_SECONDS

    def _log_trigger(self, package_name: str, trigger_reason: str, details: Dict):
        entry = {
            "timestamp_utc": datetime.now(timezone.utc).isoformat(),
            "package": package_name,
            "trigger_reason": trigger_reason,
            "details": details,
        }
        logger.info("TRIGGER: %s — %s", package_name, trigger_reason)
        try:
            with open(self.log_path, "a", encoding="utf-8") as f:
                f.write(json.dumps(entry) + "\n")
        except Exception as exc:
            logger.warning("Failed to write trigger log: %s", exc)

    def _get_account_info(self, account: str) -> Dict:
        """Get API credentials for the specified account."""
        if account == "daytrade":
            return {
                "api_key": self._daytrade_key,
                "secret_key": self._daytrade_secret,
                "base_url": self._base_url,
            }
        else:
            return {
                "api_key": self._medlong_key,
                "secret_key": self._medlong_secret,
                "base_url": os.environ.get("ALPACA_BASE_URL_MEDLONG", self._base_url),
            }

    def _get_account_equity(self, account: str) -> float:
        """Fetch account equity from Alpaca."""
        import requests as req
        creds = self._get_account_info(account)
        try:
            resp = req.get(
                f"{creds[base_url]}/v2/account",
                headers={
                    "APCA-API-KEY-ID": creds["api_key"],
                    "APCA-API-SECRET-KEY": creds["secret_key"],
                },
                timeout=10,
            )
            resp.raise_for_status()
            return float(resp.json().get("equity", 0))
        except Exception as exc:
            logger.warning("Failed to get equity for %s: %s", account, exc)
            return 100000.0 if account == "daytrade" else 500000.0

    def _get_positions(self, account: str) -> List[Dict]:
        """Fetch current positions from Alpaca."""
        import requests as req
        creds = self._get_account_info(account)
        try:
            resp = req.get(
                f"{creds[base_url]}/v2/positions",
                headers={
                    "APCA-API-KEY-ID": creds["api_key"],
                    "APCA-API-SECRET-KEY": creds["secret_key"],
                },
                timeout=10,
            )
            resp.raise_for_status()
            return resp.json()
        except Exception as exc:
            logger.warning("Failed to get positions for %s: %s", account, exc)
            return []

    def _submit_order(self, order: Dict) -> bool:
        """Submit a single order to Alpaca paper account."""
        import requests as req

        account = order.get("account", "daytrade")
        creds = self._get_account_info(account)
        symbol = order["symbol"]
        action = order["action"]

        headers = {
            "APCA-API-KEY-ID": creds["api_key"],
            "APCA-API-SECRET-KEY": creds["secret_key"],
        }
        base = creds["base_url"]

        try:
            if action == "flatten":
                # Close position if it exists
                resp = req.delete(
                    f"{base}/v2/positions/{symbol}",
                    headers=headers,
                    timeout=10,
                )
                if resp.status_code == 404:
                    logger.info("No position in %s to flatten on %s", symbol, account)
                    return True
                resp.raise_for_status()
                logger.info("FLATTENED %s on %s", symbol, account)
                return True

            elif action in ("buy", "sell_short"):
                equity = self._get_account_equity(account)
                notional_pct = order.get("notional_pct", 5.0)
                notional = round(equity * notional_pct / 100, 2)
                notional = max(notional, 1000)  # Minimum $1K

                side = "buy" if action == "buy" else "sell"
                order_data = {
                    "symbol": symbol,
                    "notional": str(notional),
                    "side": side,
                    "type": "market",
                    "time_in_force": "day",
                }
                resp = req.post(
                    f"{base}/v2/orders",
                    headers=headers,
                    json=order_data,
                    timeout=10,
                )
                resp.raise_for_status()
                logger.info("SUBMITTED %s %s $%.0f %s on %s", action.upper(), symbol, notional, order.get("reason", ""), account)
                return True

        except Exception as exc:
            logger.error("Order failed: %s %s — %s", action, symbol, exc)
            return False

        return False

    def _execute_package(self, package_name: str, trigger_reason: str, details: Dict):
        """Execute all orders in a pre-staged package."""
        if not self._is_cooled_down(package_name):
            logger.info("Package %s still in cooldown, skipping", package_name)
            return

        package = ORDER_PACKAGES.get(package_name)
        if not package:
            logger.error("Unknown package: %s", package_name)
            return

        self._log_trigger(package_name, trigger_reason, details)
        self._last_triggers[package_name] = time.time()

        logger.info("=" * 60)
        logger.info("EXECUTING PACKAGE: %s", package_name)
        logger.info("Reason: %s", trigger_reason)
        logger.info("Orders: %d", len(package["orders"]))
        logger.info("=" * 60)

        results = []
        for order in package["orders"]:
            success = self._submit_order(order)
            results.append({"order": order, "success": success})
            time.sleep(0.5)  # Rate limit between orders

        successes = sum(1 for r in results if r["success"])
        logger.info("Package %s complete: %d/%d orders succeeded", package_name, successes, len(results))

    def _check_polymarket_triggers(self) -> Optional[tuple]:
        """Check Polymarket data for trigger conditions."""
        data = self._read_json(self.polymarket_path)
        if not data:
            return None

        regime = data.get("data", {}).get("regime_evidence", {})
        peace_prob = regime.get("avg_peace_probability_pct")
        escalation_prob = regime.get("avg_escalation_probability_pct")

        # Velocity alerts
        velocity_alerts = data.get("data", {}).get("velocity_alerts", [])

        if peace_prob is not None:
            if peace_prob >= PEACE_PROB_THRESHOLD_HIGH:
                return ("PEACE_DETECTED", f"Polymarket peace probability {peace_prob:.1f}% >= {PEACE_PROB_THRESHOLD_HIGH}%",
                        {"peace_prob": peace_prob})
            if peace_prob <= PEACE_PROB_THRESHOLD_LOW and escalation_prob and escalation_prob > 50:
                return ("ESCALATION_DETECTED", f"Peace prob {peace_prob:.1f}% <= {PEACE_PROB_THRESHOLD_LOW}%, escalation {escalation_prob:.1f}%",
                        {"peace_prob": peace_prob, "escalation_prob": escalation_prob})

        # Check for rapid velocity changes
        for alert in velocity_alerts:
            if alert.get("direction") == "SURGING" and "peace" in alert.get("event", "").lower():
                return ("PEACE_DETECTED", f"Peace market surging: {alert[event]} velocity={alert[velocity]}%/hr",
                        alert)
            if alert.get("direction") == "SURGING" and any(
                kw in alert.get("event", "").lower() for kw in ["war", "escalat", "attack"]
            ):
                return ("ESCALATION_DETECTED", f"Escalation market surging: {alert[event]} velocity={alert[velocity]}%/hr",
                        alert)

        return None

    def _check_signal_triggers(self) -> Optional[tuple]:
        """Check latest_signal.json for war intensity triggers."""
        data = self._read_json(self.signal_path)
        if not data:
            return None

        # Extract war intensity score
        war_intensity = None
        for key in ("war_intensity", "war_intensity_score", "geopolitical_risk_score"):
            val = data.get(key) or data.get("data", {}).get(key)
            if val is not None:
                try:
                    war_intensity = float(val)
                    break
                except (ValueError, TypeError):
                    pass

        if war_intensity is not None:
            now = time.time()
            if self._last_war_intensity is not None and self._last_war_intensity_time is not None:
                elapsed_hours = (now - self._last_war_intensity_time) / 3600.0
                if elapsed_hours <= 1.0:
                    delta = war_intensity - self._last_war_intensity
                    if delta >= WAR_INTENSITY_JUMP:
                        self._last_war_intensity = war_intensity
                        self._last_war_intensity_time = now
                        return ("ESCALATION_DETECTED",
                                f"War intensity jumped {delta:.1f} points in {elapsed_hours:.2f}h (now {war_intensity:.1f})",
                                {"war_intensity": war_intensity, "delta": delta})
            self._last_war_intensity = war_intensity
            self._last_war_intensity_time = now

        return None

    def _check_news_triggers(self) -> Optional[tuple]:
        """Check for breaking news keywords in recent headlines."""
        # Check multiple headline sources
        headline_paths = [
            self.project_root / "data" / "quantum_feed" / "latest_signal.json",
            self.project_root / "data" / "quantum_feed" / "gdelt_snapshot.json",
        ]

        for path in headline_paths:
            data = self._read_json(path)
            if not data:
                continue

            # Extract headlines from various structures
            headlines = []
            for key in ("headlines", "breaking_news", "top_stories", "articles"):
                items = data.get(key) or data.get("data", {}).get(key, [])
                if isinstance(items, list):
                    for item in items:
                        if isinstance(item, str):
                            headlines.append(item.lower())
                        elif isinstance(item, dict):
                            title = item.get("title") or item.get("headline") or ""
                            headlines.append(title.lower())

            combined_text = " ".join(headlines)

            # Check each keyword category
            for category, keywords in BREAKING_NEWS_KEYWORDS.items():
                for kw in keywords:
                    if kw in combined_text:
                        if category == "peace":
                            if "ceasefire" in combined_text or "peace deal" in combined_text:
                                return ("CEASEFIRE_CONFIRMED", f"Breaking news keyword: {kw}",
                                        {"keyword": kw, "category": category})
                            return ("PEACE_DETECTED", f"Breaking news keyword: {kw}",
                                    {"keyword": kw, "category": category})
                        elif category == "escalation":
                            return ("ESCALATION_DETECTED", f"Breaking news keyword: {kw}",
                                    {"keyword": kw, "category": category})
                        elif category == "oil_shock":
                            return ("OIL_SHOCK", f"Breaking news keyword: {kw}",
                                    {"keyword": kw, "category": category})
                        elif category == "cyber":
                            return ("CYBER_ATTACK", f"Breaking news keyword: {kw}",
                                    {"keyword": kw, "category": category})

        return None

    def run_once(self) -> Optional[str]:
        """Run a single check cycle. Returns triggered package name or None."""
        # Check triggers in priority order
        for check_fn in [self._check_polymarket_triggers, self._check_signal_triggers, self._check_news_triggers]:
            result = check_fn()
            if result:
                package_name, reason, details = result
                if self._is_cooled_down(package_name):
                    self._execute_package(package_name, reason, details)
                    return package_name
                else:
                    logger.debug("Package %s triggered but in cooldown", package_name)
        return None

    def run_loop(self):
        """Main monitoring loop."""
        logger.info("Conditional Order Engine started")
        logger.info("Monitoring: %s", self.signal_path)
        logger.info("Monitoring: %s", self.polymarket_path)
        logger.info("Poll interval: %ds, Cooldown: %ds", POLL_INTERVAL_SECONDS, COOLDOWN_SECONDS)
        logger.info("Packages: %s", list(ORDER_PACKAGES.keys()))

        while True:
            try:
                self.run_once()
            except KeyboardInterrupt:
                logger.info("Shutting down")
                break
            except Exception as exc:
                logger.exception("Error in monitoring loop: %s", exc)

            time.sleep(POLL_INTERVAL_SECONDS)


def main():
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(name)s %(levelname)s %(message)s",
        handlers=[
            logging.StreamHandler(),
            logging.FileHandler(PROJECT_ROOT / "logs" / "conditional_orders.log"),
        ],
    )
    # Ensure log dir exists
    (PROJECT_ROOT / "logs").mkdir(exist_ok=True)

    engine = ConditionalOrderEngine()
    engine.run_loop()


if __name__ == "__main__":
    main()
