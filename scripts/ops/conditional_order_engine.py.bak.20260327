            {"symbol": "OXY", "action": "buy", "notional_pct": 5.0, "account": "medlong", "reason": "escalation_energy"},
            {"symbol": "LMT", "action": "buy", "notional_pct": 5.0, "account": "medlong", "reason": "escalation_defense"},
