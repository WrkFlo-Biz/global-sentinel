[Unit]
Description=Global Sentinel: Strategy A/B Tester (weekdays 20:45 UTC)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/opt/global-sentinel
Environment=PYTHONPATH=/opt/global-sentinel GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
ExecStart=/bin/bash -c "set -a && source /opt/global-sentinel/.env 2>/dev/null && set +a && /usr/bin/python3 /opt/global-sentinel/src/strategies/ab_tester.py >> /opt/global-sentinel/logs/ab_tester.log 2>&1"
User=openclaw
Group=openclaw
