[Unit]
Description=Global Sentinel IBM Quantum Monthly Validation
After=network.target

[Service]
Type=oneshot
User=openclaw
WorkingDirectory=/opt/global-sentinel
Environment=GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
Environment=PYTHONPATH=/opt/global-sentinel
ExecStart=/usr/bin/python3 /opt/global-sentinel/scripts/ops/ibm_quantum_validation.py
StandardOutput=journal
StandardError=journal
TimeoutStartSec=7200
