[Unit]
Description=Global Sentinel Save Close Prices
After=network.target

[Service]
Type=oneshot
User=openclaw
WorkingDirectory=/opt/global-sentinel
Environment=GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
ExecStart=/usr/bin/python3 /opt/global-sentinel/scripts/ops/overnight_gap_strategy.py close
StandardOutput=journal
StandardError=journal
