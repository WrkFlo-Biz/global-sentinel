[Unit]
Description=Global Sentinel Dashboard API
After=network.target global-sentinel.service
Wants=global-sentinel.service

[Service]
Type=simple
User=openclaw
Group=openclaw
WorkingDirectory=/opt/global-sentinel
EnvironmentFile=/opt/global-sentinel/.env
Environment=GS_REPO_ROOT=/opt/global-sentinel
ExecStart=/opt/global-sentinel/venv/bin/python3 -m uvicorn dashboard.api.server:app --host 0.0.0.0 --port 8501
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
