[Unit]
Description=Global Sentinel FRED Release Calendar
After=network.target

[Service]
Type=oneshot
User=openclaw
WorkingDirectory=/opt/global-sentinel
Environment=PYTHONPATH=/opt/global-sentinel
Environment=GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
ExecStart=/usr/bin/python3 /opt/global-sentinel/src/bridges/fred_release_calendar.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
