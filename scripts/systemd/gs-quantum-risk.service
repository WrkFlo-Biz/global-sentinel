[Unit]
Description=Global Sentinel Quantum Risk Estimator (VaR/CVaR)
After=network.target

[Service]
Type=oneshot
User=openclaw
Environment=PYTHONPATH=/opt/global-sentinel
Environment=GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
ExecStart=/usr/bin/python3 /opt/global-sentinel/src/research/quantum_risk_estimator.py
TimeoutStartSec=600
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
