[Unit]
Description=Global Sentinel: AutoResearch Strategy Optimizer (daily 07:00 UTC)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/opt/global-sentinel
Environment=PYTHONPATH=/opt/global-sentinel GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
EnvironmentFile=/opt/global-sentinel/.env
ExecStart=/bin/bash -c '/usr/bin/python3 -m src.research.auto_research_optimizer >> /opt/global-sentinel/logs/auto_research_optimizer.log 2>&1'
User=openclaw
Group=openclaw
TimeoutStartSec=1800
