TELEGRAM_V6_DIGEST_THREAD_ID=
TELEGRAM_PERFORMANCE_THREAD_ID=
TELEGRAM_CONGRESS_THREAD_ID=
TELEGRAM_SYSTEM_THREAD_ID=
TELEGRAM_BOT_TOKEN_DARKBOT=
TELEGRAM_BOT_TOKEN_DRKBOT=
TELEGRAM_CHAT_ID_DARKBOT=
TELEGRAM_CHAT_ID_DRKBOT=
TELEGRAM_ROLE_UPDATES_CHAT_ID=
TELEGRAM_ROLE_UPDATES_THREAD_ID=
TELEGRAM_ROLE_UPDATES_REPLY_TO_MESSAGE_ID=
TELEGRAM_ROLE_UPDATES_DISABLE_NOTIFICATION=false
TELEGRAM_UPDATES_MUTED_UNTIL=

# === GitHub Enterprise Bootstrap ===
GH_ENTERPRISE_HOST=github.com
GH_ENTERPRISE_ORG=your-org
GH_ENTERPRISE_REPO=global-sentinel
