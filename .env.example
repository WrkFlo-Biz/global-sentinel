# === Quantum / OriginQ Research Lane ===
GS_QUANTUM_PROVIDER=
ORIGINQ_CLOUD_URL=http://pyqanda-admin.qpanda.cn
ORIGINQ_BACKEND_NAME=
ORIGINQ_API_KEY=
ORIGINQ_PILOT_URL=
ORIGINQ_PILOT_API_KEY=
ORIGINQ_CHIP_ID=
ORIGINQ_ENABLE_LOCAL_SIM=false

# === OpenClaw Orchestration ===
# systemd can override these per service; keep .env values as shared defaults.
OPENCLAW_MIN_WORKERS=2
OPENCLAW_MAX_WORKERS=6
OPENCLAW_SEED_INTERVAL_SEC=20
OPENCLAW_DISPATCH_INTERVAL_SEC=10
OPENCLAW_REPLAY_EVERY_N_SEEDS=1
OPENCLAW_OUTCOME_EVERY_N_SEEDS=1

# === Dashboard, Alerts, and Telegram Routing ===
GS_DASHBOARD_API_KEY=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_CHAT_ID=
TELEGRAM_DEFAULT_THREAD_ID=
TELEGRAM_TRADING_THREAD_ID=
