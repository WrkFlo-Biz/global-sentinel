# Global Sentinel — environment template
# Copy to .env and populate secrets out-of-band. Do not commit real values.
# Canonical VM runtime: user=openclaw, repo=/opt/global-sentinel

# === Runtime Paths and Process Defaults ===
GLOBAL_SENTINEL_REPO_ROOT=/opt/global-sentinel
GS_REPO_ROOT=/opt/global-sentinel
PYTHONPATH=/opt/global-sentinel
GS_ENVIRONMENT=prod
GLOBAL_SENTINEL_ENV=prod
GS_LOG_LEVEL=INFO
HEARTBEAT_FILE=/tmp/global-sentinel-heartbeat
RECONCILER_LOOP_SECONDS=60
BROKER_ADAPTER=alpaca_paper
BROKER_CONFORMANCE_ADAPTER=mock
TRADE_APPROVAL_TIMEOUT=60
GS_ENABLE_V6_EXECUTION_BLOCKS=false
GS_MICROSTRUCTURE_CACHE_TTL_SEC=300
GS_MICROSTRUCTURE_MAX_SYMBOLS=40
GS_NOTIFY_PAPER_POSITIONS=true
GS_NOTIFY_LIVE_POSITIONS=false
GS_OIL_REGIME_OVERRIDE=
GS_PACKET_SIGNING_KEY=

# === Azure / Infra / Storage ===
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=OPENCLAW-RG
AZURE_LOCATION=eastus2
AZURE_VM_NAME=openclaw-gateway-vm
AZURE_KEY_VAULT_NAME=your-key-vault-name
STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_CONNECTION_STRING=
GS_AZURE_STORAGE_CONNECTION_STRING=

# === LLM / Inference Providers ===
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
NEMOTRON_API_BASE=https://openrouter.ai/api/v1
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# === Broker Credentials and Routing ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY_DAYTRADE=
ALPACA_SECRET_KEY_DAYTRADE=
ALPACA_BASE_URL_DAYTRADE=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY_MEDLONG=
ALPACA_SECRET_KEY_MEDLONG=
ALPACA_BASE_URL_MEDLONG=https://paper-api.alpaca.markets/v2
ALPACA_API_KEY_LIVE=
ALPACA_SECRET_KEY_LIVE=
ALPACA_ALLOW_LIVE=false
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_STOCK_STREAM_FEED=iex

# Optional compatibility aliases for older adapters and reports.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_DAY_TRADE_KEY=
ALPACA_DAY_TRADE_SECRET=
ALPACA_MEDIUM_LONG_KEY=
ALPACA_MEDIUM_LONG_SECRET=
ALPACA_API_KEY_MEDIUM_LONG=
ALPACA_SECRET_KEY_MEDIUM_LONG=
ALPACA_API_KEY_MEDIUMLONG=
ALPACA_SECRET_KEY_MEDIUMLONG=

TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_REMEMBER_TOKEN=
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=

IBKR_ACCOUNT_1=
IBKR_CP_BASE_URL=https://localhost:5000
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4001
IB_CLIENT_ID=1

TRADIER_TOKEN=
TRADIER_ACCOUNT_ID=
TRADIER_SANDBOX_BASE_URL=https://sandbox.tradier.com/v1
TRADIER_ALLOW_LIVE=false

# === Research and Market Data ===
FRED_API_KEY=
FRED_RATES_KEY=
FRED_API_V2_TOKEN=
EIA_API_KEY=
BLS_API_KEY=
FINNHUB_KEY=
FINNHUB_API_KEY=
