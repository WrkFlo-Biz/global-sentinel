# Global Sentinel V4 — Environment Variables
# Copy to .env and fill in real values

# === Azure OpenAI ===
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=your-anthropic-key

# === Market Data (primary) ===
POLYGON_API_KEY=your-polygon-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# === Market Data (fallback/public) ===
FRED_API_KEY=your-fred-key

# === News/Signal Sources ===
NEWSAPI_KEY=your-newsapi-key
GDELT_ENABLED=true

# === OpenClaw Bots ===
OPENCLAW_OPS_BOT_TOKEN=your-openclaw-ops-token
OPENCLAW_RESEARCH_BOT_TOKEN=your-openclaw-research-token
OPENCLAW_MAX_SUBAGENTS_OPS=5
OPENCLAW_MAX_SUBAGENTS_RESEARCH=8
OPENCLAW_AGENT_TTL_SECONDS=3600

# === Azure Infrastructure ===
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=global-sentinel-rg
AZURE_LOCATION=eastus2
AZURE_VM_NAME=gs-control-plane
AZURE_KEY_VAULT_NAME=gs-keyvault

# === GitHub Enterprise ===
GH_ENTERPRISE_HOST=github.yourcompany.com
GH_ENTERPRISE_ORG=your-org
GH_ENTERPRISE_REPO=global-sentinel

# === Monitoring ===
HEARTBEAT_FILE=/tmp/global-sentinel-heartbeat
LOG_LEVEL=INFO
CORRELATION_CHECK_INTERVAL_HOURS=6

# === Shadow Execution ===
SHADOW_MODE=true
PAPER_TRADING_ENABLED=true
LIVE_TRADING_ENABLED=false
