#!/usr/bin/env python3
"""
Global Sentinel — Strategy A/B Testing Framework

Runs daily at 4:45 PM ET. For each strategy, maintains two parameter variants.
Scores both using today's synthetic/paper trades over a 30-day rolling window.
Auto-promotes variant B if it beats A by >10% on Sharpe after 30 days.
"""
from __future__ import annotations

import copy
import json
import logging
import math
import os
import random
import sys
import urllib.request
from datetime import datetime, timezone, date, timedelta
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
)
logger = logging.getLogger("global_sentinel.ab_tester")

DOTENV = os.environ.get("GLOBAL_SENTINEL_REPO_ROOT", "/opt/global-sentinel") + "/.env"

# Parameter mutation ranges
MUTATIONS = {
    "stop_loss_pct": {"delta": 1.0, "min": 1.0, "max": 50.0},
    "take_profit_pct": {"delta": 5.0, "min": 5.0, "max": 200.0},
    "confidence_threshold": {"delta": 0.05, "min": 0.1, "max": 0.9},
    "position_size_pct": {"delta": 1.0, "min": 1.0, "max": 15.0},
}


def load_env():
    if os.path.exists(DOTENV):
        with open(DOTENV) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    os.environ.setdefault(k.strip(), v.strip())


load_env()


class StrategyABTester:
    def __init__(self):
        self.repo_root = Path(os.environ.get("GLOBAL_SENTINEL_REPO_ROOT", "/opt/global-sentinel"))
        self.qf = self.repo_root / "data" / "quantum_feed"
        self.params_path = self.qf / "optimized_params.json"
        self.results_path = self.qf / "ab_test_results.json"
        self.api_key = os.environ.get("ALPACA_API_KEY", "")
        self.api_secret = os.environ.get("ALPACA_SECRET_KEY", "")
        self.broker_url = "https://paper-api.alpaca.markets"
        self.bot_token = os.environ.get("TELEGRAM_BOT_TOKEN", "")
        self.chat_id = os.environ.get("TELEGRAM_CHAT_ID", "7091381625")

    def _api_get(self, url: str) -> Optional[Any]:
        req = urllib.request.Request(url)
        req.add_header("APCA-API-KEY-ID", self.api_key)
        req.add_header("APCA-API-SECRET-KEY", self.api_secret)
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                return json.loads(resp.read())
        except Exception as e:
            logger.warning(f"API error {url[:80]}: {e}")
            return None

    def _load_json(self, path: Path) -> Optional[Dict]:
        try:
            with open(path) as f:
                return json.load(f)
        except Exception:
            return None

    def _save_json(self, path: Path, data: Any):
        with open(path, "w") as f:
            json.dump(data, f, indent=2)

    def _send_telegram(self, text: str):
        if not self.bot_token:
            return
        url = f"https://api.telegram.org/bot{self.bot_token}/sendMessage"
        payload = json.dumps({
            "chat_id": self.chat_id,
            "text": text,
            "parse_mode": "HTML",
        }).encode()
        req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json"})
        try:
            urllib.request.urlopen(req, timeout=10)
        except Exception as e:
            logger.warning(f"Telegram failed: {e}")

    def _get_current_params(self) -> Dict:
        params = self._load_json(self.params_path)
        if not params:
            return {
                "stop_loss_pct": 5.0,
                "take_profit_pct": 15.0,
                "confidence_threshold": 0.35,
                "position_size_pct": 8.0,
            }
        return {k: params[k] for k in MUTATIONS if k in params}

    def _mutate_params(self, params: Dict) -> Dict:
        """Create variant B by randomly adjusting one or two parameters."""
        mutated = copy.deepcopy(params)
        keys = list(MUTATIONS.keys())
        n_mutations = random.choice([1, 2])
        for key in random.sample(keys, min(n_mutations, len(keys))):
            spec = MUTATIONS[key]
            direction = random.choice([-1, 1])
            new_val = mutated[key] + direction * spec["delta"]
            mutated[key] = round(max(spec["min"], min(spec["max"], new_val)), 4)
        return mutated

    def _get_todays_trades(self) -> List[Dict]:
        """Fetch today's closed orders from paper account."""
        today_str = date.today().isoformat()
        data = self._api_get(
            f"{self.broker_url}/v2/orders?status=closed&after={today_str}T00:00:00Z&limit=50"
        )
        return data or []

    def _simulate_variant_score(
        self, trades: List[Dict], params: Dict, portfolio_value: float
    ) -> Dict:
        """
        Score a parameter variant against today's trades.
        Simulates what P&L would have been with these params.
        """
        if not trades or portfolio_value <= 0:
            return {"sharpe": 0, "win_rate": 0, "avg_pnl": 0, "max_drawdown": 0, "n_trades": 0}

        returns = []
        wins = 0
        peak = portfolio_value
        max_dd = 0
        running_value = portfolio_value

        for trade in trades:
            filled_price = float(trade.get("filled_avg_price", 0) or 0)
            qty = float(trade.get("filled_qty", 0) or 0)
            side = trade.get("side", "buy")
            if filled_price <= 0 or qty <= 0:
                continue

            # Simulate P&L adjusted by variant params
            # Position size scaling
            size_ratio = params.get("position_size_pct", 8) / 8.0
            notional = filled_price * qty * size_ratio

            # Use confidence threshold to filter: higher threshold = fewer trades
            confidence = params.get("confidence_threshold", 0.35)
            # Simulate skip if confidence too high (randomly based on threshold)
            if random.random() < (confidence - 0.3):
                continue

            # Simulate stop/take-profit effect on returns
            base_return = random.gauss(0.002, 0.015)  # small positive edge
            stop = params.get("stop_loss_pct", 5) / 100
            tp = params.get("take_profit_pct", 15) / 100
            clamped_return = max(-stop, min(tp, base_return))

            pnl = notional * clamped_return
            returns.append(clamped_return)
            if pnl > 0:
                wins += 1

            running_value += pnl
            peak = max(peak, running_value)
            dd = (peak - running_value) / peak if peak > 0 else 0
            max_dd = max(max_dd, dd)

        n = len(returns)
        if n == 0:
            return {"sharpe": 0, "win_rate": 0, "avg_pnl": 0, "max_drawdown": 0, "n_trades": 0}

        avg_ret = sum(returns) / n
        std_ret = math.sqrt(sum((r - avg_ret) ** 2 for r in returns) / max(n - 1, 1))
        sharpe = (avg_ret / std_ret * math.sqrt(252)) if std_ret > 0 else 0

        return {
            "sharpe": round(sharpe, 4),
            "win_rate": round(wins / n * 100, 1),
            "avg_pnl": round(avg_ret * 100, 4),
            "max_drawdown": round(max_dd * 100, 2),
            "n_trades": n,
        }

    def _load_results(self) -> Dict:
        data = self._load_json(self.results_path)
        if not data:
            return {"strategies": {}, "last_updated": None}
        return data

    def run(self):
        logger.info("A/B Tester starting...")
        now = datetime.now(timezone.utc)
        today_str = date.today().isoformat()

        # Get account equity
        acct = self._api_get(f"{self.broker_url}/v2/account")
        portfolio_value = float(acct.get("equity", 100000)) if acct else 100000

        # Get today's trades
        trades = self._get_todays_trades()
        logger.info(f"Found {len(trades)} closed trades today")

        # Load current state
        results = self._load_results()
        strategies = results.get("strategies", {})

        # Current params = our single optimized strategy (can expand later)
        current_params = self._get_current_params()
        strategy_name = "optimized_ensemble"

        if strategy_name not in strategies:
            strategies[strategy_name] = {
                "variant_a": {"params": current_params, "scores": []},
                "variant_b": {"params": self._mutate_params(current_params), "scores": []},
                "created": today_str,
                "promotions": 0,
            }

        strat = strategies[strategy_name]

        # Score both variants
        score_a = self._simulate_variant_score(trades, strat["variant_a"]["params"], portfolio_value)
        score_b = self._simulate_variant_score(trades, strat["variant_b"]["params"], portfolio_value)

        score_a["date"] = today_str
        score_b["date"] = today_str

        strat["variant_a"]["scores"].append(score_a)
        strat["variant_b"]["scores"].append(score_b)

        # Keep 30-day rolling window
        strat["variant_a"]["scores"] = strat["variant_a"]["scores"][-30:]
        strat["variant_b"]["scores"] = strat["variant_b"]["scores"][-30:]

        logger.info(f"  Variant A score: {score_a}")
        logger.info(f"  Variant B score: {score_b}")

        # Check for promotion (need at least 30 days)
        promoted = False
        a_scores = strat["variant_a"]["scores"]
        b_scores = strat["variant_b"]["scores"]

        if len(a_scores) >= 30 and len(b_scores) >= 30:
            avg_sharpe_a = sum(s["sharpe"] for s in a_scores) / len(a_scores)
            avg_sharpe_b = sum(s["sharpe"] for s in b_scores) / len(b_scores)

            logger.info(f"  30-day avg Sharpe: A={avg_sharpe_a:.4f}, B={avg_sharpe_b:.4f}")

            if avg_sharpe_a > 0 and avg_sharpe_b > avg_sharpe_a * 1.10:
                # Promote B
                old_params = copy.deepcopy(strat["variant_a"]["params"])
                strat["variant_a"]["params"] = copy.deepcopy(strat["variant_b"]["params"])
                strat["variant_a"]["scores"] = []
                strat["variant_b"]["params"] = self._mutate_params(strat["variant_a"]["params"])
                strat["variant_b"]["scores"] = []
                strat["promotions"] = strat.get("promotions", 0) + 1
                promoted = True

                # Also update optimized_params.json
                opt = self._load_json(self.params_path) or {}
                opt.update(strat["variant_a"]["params"])
                opt["ab_promoted_at"] = now.isoformat()
                self._save_json(self.params_path, opt)

                msg = (
                    f"<b>A/B TEST: {strategy_name} variant B promoted!</b>\n"
                    f"New Sharpe: {avg_sharpe_b:.4f} vs old {avg_sharpe_a:.4f}\n"
                    f"New params: {json.dumps(strat['variant_a']['params'], indent=1)}"
                )
                self._send_telegram(msg)
                logger.info(f"  PROMOTED variant B! Sharpe {avg_sharpe_b:.4f} > {avg_sharpe_a:.4f}")

        # Summary
        summary = {
            "variant_a_params": strat["variant_a"]["params"],
            "variant_b_params": strat["variant_b"]["params"],
            "days_collected_a": len(strat["variant_a"]["scores"]),
            "days_collected_b": len(strat["variant_b"]["scores"]),
            "today_score_a": score_a,
            "today_score_b": score_b,
            "promoted_today": promoted,
        }
        if len(a_scores) >= 2:
            summary["rolling_sharpe_a"] = round(
                sum(s["sharpe"] for s in a_scores) / len(a_scores), 4
            )
        if len(b_scores) >= 2:
            summary["rolling_sharpe_b"] = round(
                sum(s["sharpe"] for s in b_scores) / len(b_scores), 4
            )

        results["strategies"] = strategies
        results["last_updated"] = now.isoformat()
        results["summary"] = summary

        self._save_json(self.results_path, results)
        logger.info(f"Results saved to {self.results_path}")
        logger.info("A/B Tester complete.")


if __name__ == "__main__":
    tester = StrategyABTester()
    tester.run()
